    },
    "item": [
        {
            "name": "Wines",
            "item": [
                {
                    "name": "List Wines",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{API_KEY}}",
                                "type": "text"
                            },
                            {
                                "key": "Accept-Language",
                                "value": "{{LANGUAGE}}",
                                "type": "text",
                                "description": "Language for residual_sugar and region names (de, en, fr, it)"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/wines?page=1&per_page=15",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "wines"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "Page number"
                                },
                                {
                                    "key": "per_page",
                                    "value": "15",
                                    "description": "Items per page (max: 100)"
                                },
                                {
                                    "key": "color",
                                    "value": "red",
                                    "description": "Filter by color (red, white, rose)",
                                    "disabled": true
                                },
                                {
                                    "key": "sub_type",
                                    "value": "still",
                                    "description": "Filter by type (still, sparkling)",
                                    "disabled": true
                                },
                                {
                                    "key": "producer_id",
                                    "value": "1771",
                                    "description": "Filter by producer ID",
                                    "disabled": true
                                },
                                {
                                    "key": "region_id",
                                    "value": "210",
                                    "description": "Filter by region ID",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Retrieve a paginated list of wines. Supports filtering by color, type, producer, and region."
